# Copy to `.env` for local dev. No trailing slash.
EXPO_PUBLIC_MOCKHU_API_BASE_URL=http://localhost:8080

# Optional alias (same as EXPO_PUBLIC_MOCKHU_API_BASE_URL if you prefer a generic name):
# EXPO_PUBLIC_API_URL=http://localhost:8080

# Optional (__DEV__ only): pause before each API fetch so loading states are visible (ms). 0 = off.
# EXPO_PUBLIC_MOCKHU_API_DEV_DELAY_MS=400

# Optional: public HTTPS URL for the Mockhu logo (same asset as server EMAIL_OTP_LOGO_URL for email OTP parity).
# EXPO_PUBLIC_BRAND_LOGO_URL=https://cdn.example.com/mockhu-logo.png

# Google Sign-In (OAuth client IDs — public; still keep them in `.env`, not in git).
# Create separate OAuth clients in Google Cloud: iOS (offers “Download plist”), Android, and Web application.
# The app falls back: if iOS/Android env is missing, it uses WEB for that platform (handy for quick tests).
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=....apps.googleusercontent.com
