# Copy to `.env`. Restart Metro after changes: `npx expo start -c`

# Mockhu API (no trailing slash). Simulator: localhost is OK. Physical device: use your PC's LAN IP, e.g.
# http://192.168.1.10:8080 — not localhost.
# Do not use port 8081 here — that is Expo Metro (bundler), not your API; requests will get HTML, not JSON.
EXPO_PUBLIC_MOCKHU_API_BASE_URL=http://localhost:8080

# Optional alias for EXPO_PUBLIC_MOCKHU_API_BASE_URL:
# EXPO_PUBLIC_API_URL=http://localhost:8080

# Optional (__DEV__ only): delay each API fetch (ms). 0 = off.
# EXPO_PUBLIC_MOCKHU_API_DEV_DELAY_MS=400

# Optional brand logo URL for in-app/email parity.
# EXPO_PUBLIC_BRAND_LOGO_URL=https://cdn.example.com/mockhu-logo.png

# Google Sign-In (@react-native-google-signin/google-signin; development build required, not Expo Go).
# Setup: https://react-native-google-signin.github.io/docs/setting-up/expo — then: npx expo prebuild --clean && npx expo run:ios (and/or run:android).
# Web client ID is required. iOS client ID required on iOS — app.config.js derives iosUrlScheme from it (doc: com.googleusercontent.apps.*).
# Android: add OAuth client with package com.mockhu.oauth + your debug/release SHA-1 in Google Cloud.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=....apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=....apps.googleusercontent.com
# Full Google + Mockhu login: POST /auth/google with id_token (omit or 0 = log Google user to Metro only).
# EXPO_PUBLIC_MOCKHU_GOOGLE_AUTH=1
